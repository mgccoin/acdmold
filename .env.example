# ============================================================================
# Lead form → Google Sheets webhook
# ============================================================================
# Paste the Web App URL produced by deploying the Apps Script in
# scripts/google-apps-script-lead-webhook.gs as a Web App.
# Looks like: https://script.google.com/macros/s/AKfycbx.../exec
GOOGLE_SHEETS_WEBHOOK_URL=

# Shared secret string. Set the SAME value in the Apps Script (SHARED_SECRET
# at the top) and here. Prevents random people from posting fake leads.
LEAD_WEBHOOK_SECRET=change-me-to-a-long-random-string

# ============================================================================
# Optional: notify your phone via SMS or your inbox via email on every lead.
# ============================================================================
# These are read by the Apps Script, NOT by Next.js. Set them in
# Apps Script's Project Settings → Script Properties.
#   NOTIFY_EMAIL = info@acdmold.com
#   NOTIFY_PHONE = +14243527034   (used only if you wire up a Twilio integration)

# ============================================================================
# Webmaster tools verification (GEO / SEO)
# ============================================================================
# Get each value from the corresponding webmaster console and paste below.
# They are surfaced in <head> via Next's `metadata.verification` config.
#
# Google Search Console: https://search.google.com/search-console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools: https://www.bing.com/webmasters
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Yandex Webmaster: https://webmaster.yandex.com (optional — helps with Eastern
# European AI engines and Yandex.GPT citations)
NEXT_PUBLIC_YANDEX_SITE_VERIFICATION=
